  /BitsPerComponent 8 def
  /Decode [ 0 1 0 1 0 1 ] def
  /DataSource currentfile /ASCII85Decode filter /LZWDecode filter def
  /Interpolate true def
  /ImageMatrix [ 1 0 0 -1 0 427 ] def
end
